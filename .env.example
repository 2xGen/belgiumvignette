# Supabase (server-side only — never expose service role key to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://belgiumvignette.be

# Search engine ownership verification (optional — meta tags in <head>)
# Google Search Console: HTML tag method → paste the content value only
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: meta tag content (default baked in; override if needed)
NEXT_PUBLIC_BING_SITE_VERIFICATION=D56EB4A1FD92FE4D0287836170CEF0FC
